contract {{TEST_NAME}} is Test {
    address constant TARGET = {{TARGET_ADDRESS}};
    address constant ATTACKER = address(0xA77ACE);
    address constant VICTIM = {{VICTIM_ADDRESS}};

    function setUp() public {
        vm.createSelectFork(vm.envString("{{RPC_ENV_VAR}}"), {{FORK_BLOCK}});
        vm.label(TARGET, "{{TARGET_CONTRACT}}");
        vm.deal(ATTACKER, 100 ether);
    }

    function test_{{TEST_NAME_SUFFIX}}_validation_gap() public {
        // === BEFORE STATE ===
        uint256 attackerBalBefore = {{BALANCE_BEFORE_EXPR}};
        uint256 victimBalBefore = {{VICTIM_BALANCE_BEFORE_EXPR}};

        vm.startPrank(ATTACKER);

        // === TRIGGER WITH MALICIOUS PARAMS ===
        {{MALICIOUS_CALL}}

        vm.stopPrank();

        // === AFTER STATE ===
        uint256 attackerBalAfter = {{BALANCE_AFTER_EXPR}};
        uint256 victimBalAfter = {{VICTIM_BALANCE_AFTER_EXPR}};

        // === EXPLOIT ASSERTIONS ===
        assertGt(attackerBalAfter, attackerBalBefore, "attacker should profit");
        assertLt(victimBalAfter, victimBalBefore, "victim should lose");
    }
}
